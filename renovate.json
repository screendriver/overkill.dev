{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"dependencyDashboard": true,
	"labels": ["renovate"],
	"lockFileMaintenance": {
		"enabled": true,
		"automerge": true
	},
	"packageRules": [
		{
			"matchManagers": ["woodpecker"],
			"matchPackageNames": ["node"],
			"enabled": false
		},
		{
			"matchFileNames": [".woodpecker/*.yaml"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true,
			"automergeType": "branch"
		},
		{
			"matchDepTypes": ["dependencies", "devDependencies"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true,
			"automergeType": "branch"
		},
		{
			"groupName": "Fontsource dependencies",
			"groupSlug": "fontsource-dependencies",
			"matchPackageNames": ["@fontsource/*"]
		},
		{
			"groupName": "Node.js",
			"groupSlug": "nodejs",
			"matchPackageNames": ["node"],
			"automerge": false
		}
	],
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": ["/^\\.woodpecker\\/deploy\\.yaml$/", "/^\\.woodpecker\\/test\\.yaml$/"],
			"matchStrings": ["image:\\s*node:(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
			"depNameTemplate": "node",
			"datasourceTemplate": "node",
			"versioningTemplate": "node"
		}
	]
}
